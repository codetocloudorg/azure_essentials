{
  "name": "Azure Essentials - Code to Cloud",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.vscode-node-azure-pack",
        "ms-azuretools.vscode-bicep",
        "ms-azuretools.vscode-azurefunctions",
        "ms-azuretools.vscode-azurelogicapps",
        "ms-azuretools.vscode-cosmosdb",
        "ms-azuretools.vscode-docker",
        "ms-azuretools.vscode-azureappservice",
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "ms-dotnettools.csharp",
        "ms-dotnettools.vscode-dotnet-runtime",
        "HashiCorp.terraform",
        "redhat.vscode-yaml",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "humao.rest-client",
        "github.copilot",
        "github.copilot-chat",
        "esbenp.prettier-vscode",
        "eamodio.gitlens"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "editor.formatOnSave": true,
        "editor.minimap.enabled": false,
        "files.trimTrailingWhitespace": true,
        "yaml.schemas": {
          "https://raw.githubusercontent.com/Azure/azure-dev/main/schemas/v1.0/azure.yaml.json": "azure.yaml"
        }
      }
    }
  },
  "postCreateCommand": "cat /etc/motd",
  "remoteUser": "vscode",
  "mounts": [
    "source=${localEnv:HOME}/.azure,target=/home/vscode/.azure,type=bind,consistency=cached"
  ],
  "forwardPorts": [
    7071,
    3000,
    8080
  ],
  "portsAttributes": {
    "7071": {
      "label": "Azure Functions",
      "onAutoForward": "notify"
    },
    "3000": {
      "label": "Web App",
      "onAutoForward": "notify"
    },
    "8080": {
      "label": "API",
      "onAutoForward": "notify"
    }
  }
}
